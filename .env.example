# ----------------------------------------------------------------------------
# access-request-classifier — example environment file
#
# Usage:
#   1. Copy this file to .env:   cp .env.example .env
#   2. Fill in the required values below (anything marked REQUIRED).
#   3. Run: docker compose up
# ----------------------------------------------------------------------------

# --- LLM (REQUIRED) ----------------------------------------------------------
# API key for the hosted LLM used for structured-output classification.
LLM_API_KEY=your-llm-api-key-here

# Which provider adapter to use. Only read when running the app directly
# (docker compose does not forward this to the app container).
# LLM_PROVIDER=default

# --- Database ----------------------------------------------------------------
# Postgres credentials used by docker compose to provision the db service and
# to build the app's DATABASE_URL.
POSTGRES_PASSWORD=change-me        # REQUIRED — compose fails without it
POSTGRES_USER=postgres             # optional, defaults to "postgres"
POSTGRES_DB=access_requests        # optional, defaults to "access_requests"

# Direct connection string. Leave commented when using docker compose (it is
# assembled automatically from the POSTGRES_* values above). Set it explicitly
# only when running the app outside compose.
# DATABASE_URL=postgresql://postgres:change-me@localhost:5432/access_requests

# --- Classification / anomaly tuning (optional) ------------------------------
# Score at or above which a request is flagged as anomalous (0.0–1.0).
ANOMALY_THRESHOLD=0.5

# Cold-start behavior: requesters with fewer than this many prior requests get
# assigned a fixed anomaly score instead of a computed one.
# (App-direct runs only; not forwarded by docker compose.)
# COLD_START_MIN_HISTORY=2
# COLD_START_ANOMALY_SCORE=0.8

# Fallback reviewer queue when no specific approver can be recommended.
# (App-direct runs only; not forwarded by docker compose.)
# DEFAULT_REVIEWER_QUEUE=default-reviewer-queue
